--[[
    ============================================================
    COZY UI - RESPONSIVE ENGINES (MOBILE & PC AUTO-SWITCH)
    ============================================================
]]

local CozyUI = {}
CozyUI.__index = CozyUI

local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")

local function getRandomName()
    local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
    local name = ""
    for i = 1, 14 do
        local rand = math.random(1, #chars)
        name = name .. string.sub(chars, rand, rand)
    end
    return name
end

function CozyUI:CreateWindow(config)
    local window = setmetatable({}, CozyUI)
    window.Title = config.Name or "Cozy Hub"
    window.Tabs = {}
    window.TabButtons = {}
    window.Pages = {}
    
    -- Screen Setup
    local sgui = Instance.new("ScreenGui")
    sgui.Name = getRandomName()
    sgui.ResetOnSpawn = false
    sgui.DisplayOrder = 999
    
    local success, p = pcall(function() return gethui() end)
    sgui.Parent = (success and p) or CoreGui
    
    -- Main Container Frame
    local mainFrame = Instance.new("Frame")
    mainFrame.Name = getRandomName()
    mainFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    mainFrame.BorderSizePixel = 0
    mainFrame.Active = true
    mainFrame.Draggable = true
    mainFrame.Parent = sgui
    
    local mainStroke = Instance.new("UIStroke")
    mainStroke.Thickness = 1
    mainStroke.Color = Color3.fromRGB(255, 255, 255)
    mainStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    mainStroke.Parent = mainFrame

    -- Title Bar
    local titleLabel = Instance.new("TextLabel")
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = " " .. window.Title
    titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    titleLabel.Font = Enum.Font.Code
    titleLabel.TextSize = 13
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = mainFrame
    
    -- Navigation Holder
    local navFrame = Instance.new("Frame")
    navFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    navFrame.Parent = mainFrame
    
    local navStroke = Instance.new("UIStroke")
    navStroke.Thickness = 1
    navStroke.Color = Color3.fromRGB(40, 40, 40)
    navStroke.Parent = navFrame
    
    local navLayout = Instance.new("UIListLayout")
    navLayout.Padding = UDim.new(0, 4)
    navLayout.Parent = navFrame
    
    -- Content View Window
    local container = Instance.new("Frame")
    container.BackgroundColor3 = Color3.fromRGB(5, 5, 5)
    container.Parent = mainFrame
    
    local containerStroke = Instance.new("UIStroke")
    containerStroke.Thickness = 1
    containerStroke.Color = Color3.fromRGB(40, 40, 40)
    containerStroke.Parent = container

    window.MainFrame = mainFrame
    window.NavFrame = navFrame
    window.NavLayout = navLayout
    window.Container = container
    window.TitleLabel = titleLabel

    -- Responsive Engine Check (PC vs Mobile Viewport Layout scaling)
    local camera = Workspace.CurrentCamera
    local function applyResponsiveLayout()
        local viewportSize = camera.ViewportSize
        if viewportSize.X <= 768 then
            -- MOBILE UI TRANSFORMATION Layout Setup
            mainFrame.Size = UDim2.new(0, 360, 0, 260)
            mainFrame.Position = UDim2.new(0.5, -180, 0.5, -130)
            
            titleLabel.Size = UDim2.new(1, 0, 0, 25)
            titleLabel.Position = UDim2.new(0, 5, 0, 0)
            
            navFrame.Size = UDim2.new(1, -12, 0, 32)
            navFrame.Position = UDim2.new(0, 6, 0, 25)
            navLayout.FillDirection = Enum.FillDirection.Horizontal
            
            container.Size = UDim2.new(1, -12, 1, -68)
            container.Position = UDim2.new(0, 6, 0, 62)
            
            for _, btn in pairs(window.TabButtons) do
                btn.Size = UDim2.new(0, 80, 1, 0)
            end
        else
            -- PC UI DESIGN WIDESCREEN SETUP
            mainFrame.Size = UDim2.new(0, 580, 0, 360)
            mainFrame.Position = UDim2.new(0.5, -290, 0.5, -180)
            
            titleLabel.Size = UDim2.new(1, 0, 0, 30)
            titleLabel.Position = UDim2.new(0, 10, 0, 0)
            
            navFrame.Size = UDim2.new(0, 130, 1, -40)
            navFrame.Position = UDim2.new(0, 10, 0, 35)
            navLayout.FillDirection = Enum.FillDirection.Vertical
            
            container.Size = UDim2.new(1, -160, 1, -40)
            container.Position = UDim2.new(0, 150, 0, 35)
            
            for _, btn in pairs(window.TabButtons) do
                btn.Size = UDim2.new(1, 0, 0, 28)
            end
        end
    end
    
    applyResponsiveLayout()
    camera:GetPropertyChangedSignal("ViewportSize"):Connect(applyResponsiveLayout)
    
    -- Setup Built-In Systems
    window:CreateInfoTab()
    window:CreateExecutorTab()
    
    return window
end

function CozyUI:CreateTab(tabName)
    local tab = {}
    local window = self
    
    local tabBtn = Instance.new("TextButton")
    tabBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    tabBtn.Text = tabName
    tabBtn.TextColor3 = Color3.fromRGB(160, 160, 160)
    tabBtn.Font = Enum.Font.Code
    tabBtn.TextSize = 12
    tabBtn.Parent = self.NavFrame
    
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 1
    btnStroke.Color = Color3.fromRGB(30, 30, 30)
    btnStroke.Parent = tabBtn
    
    table.insert(window.TabButtons, tabBtn)
    
    -- Force initial size updates
    local camera = Workspace.CurrentCamera
    if camera.ViewportSize.X <= 768 then
        tabBtn.Size = UDim2.new(0, 80, 1, 0)
    else
        tabBtn.Size = UDim2.new(1, 0, 0, 28)
    end

    local page = Instance.new("ScrollingFrame")
    page.Size = UDim2.new(1, -10, 1, -10)
    page.Position = UDim2.new(0, 5, 0, 5)
    page.BackgroundTransparency = 1
    page.Visible = false
    page.CanvasSize = UDim2.new(0, 0, 0, 0)
    page.AutomaticSize = Enum.AutomaticSize.Y
    page.ScrollBarThickness = 2
    page.ScrollBarImageColor3 = Color3.fromRGB(255, 255, 255)
    page.Parent = self.Container
    
    local pageLayout = Instance.new("UIListLayout")
    pageLayout.Padding = UDim.new(0, 6)
    pageLayout.Parent = page
    
    table.insert(window.Pages, page)
    
    local function selectThisTab()
        for _, p in pairs(window.Pages) do p.Visible = false end
        for _, b in pairs(window.TabButtons) do 
            b.TextColor3 = Color3.fromRGB(160, 160, 160)
            b.UIStroke.Color = Color3.fromRGB(30, 30, 30)
        end
        page.Visible = true
        tabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        tabBtn.UIStroke.Color = Color3.fromRGB(255, 255, 255)
    end
    
    tabBtn.MouseButton1Click:Connect(selectThisTab)
    if #window.Pages == 1 then selectThisTab() end
    
    function tab:CreateButton(name, callback)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -4, 0, 30)
        btn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
        btn.Text = name
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.Code
        btn.TextSize = 12
        btn.Parent = page
        
        local s = Instance.new("UIStroke")
        s.Thickness = 1
        s.Color = Color3.fromRGB(255, 255, 255)
        s.Parent = btn
        
        btn.MouseButton1Click:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            btn.TextColor3 = Color3.fromRGB(0, 0, 0)
            task.wait(0.05)
            btn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            pcall(callback)
        end)
    end
    
    return tab
end

function CozyUI:CreateInfoTab()
    local window = self
    local infoBtn = Instance.new("TextButton")
    infoBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    infoBtn.Text = "Profile Info"
    infoBtn.TextColor3 = Color3.fromRGB(160, 160, 160)
    infoBtn.Font = Enum.Font.Code
    infoBtn.TextSize = 12
    infoBtn.Parent = self.NavFrame
    
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 1
    btnStroke.Color = Color3.fromRGB(30, 30, 30)
    btnStroke.Parent = infoBtn
    
    table.insert(window.TabButtons, infoBtn)

    local infoPage = Instance.new("Frame")
    infoPage.Size = UDim2.new(1, -10, 1, -10)
    infoPage.Position = UDim2.new(0, 5, 0, 5)
    infoPage.BackgroundTransparency = 1
    infoPage.Visible = false
    infoPage.Parent = self.Container
    
    table.insert(window.Pages, infoPage)
    
    -- Left Text Info Layout Stack
    local infoList = Instance.new("Frame")
    infoList.Size = UDim2.new(0.5, -5, 1, 0)
    infoList.BackgroundTransparency = 1
    infoList.Parent = infoPage
    
    local ilist = Instance.new("UIListLayout")
    ilist.Padding = UDim.new(0, 4)
    ilist.Parent = infoList
    
    local function createMetaLabel(txt)
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, 0, 0, 22)
        lbl.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
        lbl.Text = " " .. txt
        lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
        lbl.Font = Enum.Font.Code
        lbl.TextSize = 11
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Parent = infoList
        local s = Instance.new("UIStroke")
        s.Thickness = 1
        s.Color = Color3.fromRGB(40, 40, 40)
        s.Parent = lbl
    end
    
    createMetaLabel("User: " .. LocalPlayer.Name)
    createMetaLabel("Display: " .. LocalPlayer.DisplayName)
    createMetaLabel("Account Age: " .. tostring(LocalPlayer.AccountAge) .. " days")
    createMetaLabel("ID: " .. tostring(LocalPlayer.UserId))

    -- Upgraded 3D Viewport
    local viewport = Instance.new("ViewportFrame")
    viewport.Size = UDim2.new(0.5, -5, 1, 0)
    viewport.Position = UDim2.new(0.5, 5, 0, 0)
    viewport.BackgroundColor3 = Color3.fromRGB(12, 12, 12)
    viewport.Parent = infoPage
    
    local vStroke = Instance.new("UIStroke")
    vStroke.Thickness = 1
    vStroke.Color = Color3.fromRGB(255, 255, 255)
    vStroke.Parent = viewport
    
    task.spawn(function()
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        char.Archivable = true
        task.wait(0.5)
        local clone = char:Clone()
        clone.Parent = viewport
        
        local hrp = clone:WaitForChild("HumanoidRootPart")
        local cam = Instance.new("Camera")
        viewport.CurrentCamera = cam
        cam.Parent = viewport
        
        local rotAngle = 0
        game:GetService("RunService").Heartbeat:Connect(function()
            rotAngle = rotAngle + 1
            cam.CFrame = CFrame.new(hrp.Position + Vector3.new(math.sin(math.rad(rotAngle)) * 5, 2, math.cos(math.rad(rotAngle)) * 5), hrp.Position)
        end)
    end)

    infoBtn.MouseButton1Click:Connect(function()
        for _, p in pairs(window.Pages) do p.Visible = false end
        for _, b in pairs(window.TabButtons) do 
            b.TextColor3 = Color3.fromRGB(160, 160, 160)
            b.UIStroke.Color = Color3.fromRGB(30, 30, 30)
        end
        infoPage.Visible = true
        infoBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        infoBtn.UIStroke.Color = Color3.fromRGB(255, 255, 255)
    end)
end

function CozyUI:CreateExecutorTab()
    local window = self
    local execBtn = Instance.new("TextButton")
    execBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    execBtn.Text = "Internal Exec"
    execBtn.TextColor3 = Color3.fromRGB(160, 160, 160)
    execBtn.Font = Enum.Font.Code
    execBtn.TextSize = 12
    execBtn.Parent = self.NavFrame
    
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 1
    btnStroke.Color = Color3.fromRGB(30, 30, 30)
    btnStroke.Parent = execBtn
    
    table.insert(window.TabButtons, execBtn)

    local execPage = Instance.new("Frame")
    execPage.Size = UDim2.new(1, -10, 1, -10)
    execPage.Position = UDim2.new(0, 5, 0, 5)
    execPage.BackgroundTransparency = 1
    execPage.Visible = false
    execPage.Parent = self.Container
    
    table.insert(window.Pages, execPage)
    
    -- TextBox Console Terminal Input
    local textBox = Instance.new("TextBox")
    textBox.Size = UDim2.new(1, 0, 1, -35)
    textBox.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    textBox.ClearTextOnFocus = false
    textBox.MultiLine = true
    textBox.Text = "-- Enter custom Luau script lines here..."
    textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    textBox.Font = Enum.Font.Code
    textBox.TextSize = 11
    textBox.TextXAlignment = Enum.TextXAlignment.Left
    textBox.TextYAlignment = Enum.TextYAlignment.Top
    textBox.Parent = execPage
    
    local tStroke = Instance.new("UIStroke")
    tStroke.Thickness = 1
    tStroke.Color = Color3.fromRGB(40, 40, 40)
    tStroke.Parent = textBox
    
    -- Run Action Button
    local runBtn = Instance.new("TextButton")
    runBtn.Size = UDim2.new(0.5, -4, 0, 28)
    runBtn.Position = UDim2.new(0, 0, 1, -28)
    runBtn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    runBtn.Text = "Execute Script"
    runBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    runBtn.Font = Enum.Font.Code
    runBtn.TextSize = 12
    runBtn.Parent = execPage
    
    local rbStroke = Instance.new("UIStroke")
    rbStroke.Thickness = 1
    rbStroke.Color = Color3.fromRGB(255, 255, 255)
    rbStroke.Parent = runBtn
    
    -- Clear Action Button
    local clearBtn = Instance.new("TextButton")
    clearBtn.Size = UDim2.new(0.5, -4, 0, 28)
    clearBtn.Position = UDim2.new(0.5, 4, 1, -28)
    clearBtn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    clearBtn.Text = "Clear Console"
    clearBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    clearBtn.Font = Enum.Font.Code
    clearBtn.TextSize = 12
    clearBtn.Parent = execPage
    
    local cbStroke = Instance.new("UIStroke")
    cbStroke.Thickness = 1
    cbStroke.Color = Color3.fromRGB(255, 255, 255)
    cbStroke.Parent = clearBtn
    
    runBtn.MouseButton1Click:Connect(function()
        local code = textBox.Text
        if code and code ~= "" then
            local func, err = loadstring(code)
            if func then
                task.spawn(func)
            else
                warn("Cozy Exec Error: " .. tostring(err))
            end
        end
    end)
    
    clearBtn.MouseButton1Click:Connect(function()
        textBox.Text = ""
    end)

    execBtn.MouseButton1Click:Connect(function()
        for _, p in pairs(window.Pages) do p.Visible = false end
        for _, b in pairs(window.TabButtons) do 
            b.TextColor3 = Color3.fromRGB(160, 160, 160)
            b.UIStroke.Color = Color3.fromRGB(30, 30, 30)
        end
        execPage.Visible = true
        execBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        execBtn.UIStroke.Color = Color3.fromRGB(255, 255, 255)
    end)
end

return CozyUI
