local CozyUI = {}
CozyUI.__index = CozyUI

-- Base CoreGui / Viewport detection
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local TweenService = game:GetService("TweenService")

-- Generate a completely randomized name for stealth
local function getRandomName()
    local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz01233456789"
    local name = ""
    for i = 1, 12 do
        local rand = math.random(1, #chars)
        name = name .. string.sub(chars, rand, rand)
    end
    return name
end

function CozyUI:CreateWindow(config)
    local window = setmetatable({}, CozyUI)
    window.Title = config.Name or "Cozy Hub"
    window.Tabs = {}
    
    -- Main Screen Gui
    local sgui = Instance.new("ScreenGui")
    sgui.Name = getRandomName()
    sgui.ResetOnSpawn = false
    sgui.DisplayOrder = 999
    
    -- Stealth parenting check
    local success, p = pcall(function() return gethui() end)
    sgui.Parent = (success and p) or CoreGui
    
    -- Main Container
    local mainFrame = Instance.new("Frame")
    mainFrame.Name = getRandomName()
    mainFrame.Size = UDim2.new(0, 550, 0, 350)
    mainFrame.Position = UDim2.new(0.5, -275, 0.5, -175)
    mainFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    mainFrame.BorderSizePixel = 0
    mainFrame.Parent = sgui
    
    -- Solid 1px White Outline
    local mainStroke = Instance.new("UIStroke")
    mainStroke.Thickness = 1
    mainStroke.Color = Color3.fromRGB(255, 255, 255)
    mainStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    mainStroke.Parent = mainFrame

    -- Title Bar
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -20, 0, 30)
    titleLabel.Position = UDim2.new(0, 10, 0, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = window.Title
    titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    titleLabel.Font = Enum.Font.Code
    titleLabel.TextSize = 14
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = mainFrame
    
    -- Sidebar Navigation Frame
    local sidebar = Instance.new("Frame")
    sidebar.Size = UDim2.new(0, 130, 1, -40)
    sidebar.Position = UDim2.new(0, 10, 0, 35)
    sidebar.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    sidebar.Parent = mainFrame
    
    local sideStroke = Instance.new("UIStroke")
    sideStroke.Thickness = 1
    sideStroke.Color = Color3.fromRGB(40, 40, 40)
    sideStroke.Parent = sidebar
    
    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 4)
    layout.Parent = sidebar
    
    -- Content Frame
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1, -160, 1, -40)
    container.Position = UDim2.new(0, 150, 0, 35)
    container.BackgroundColor3 = Color3.fromRGB(5, 5, 5)
    container.Parent = mainFrame
    
    local containerStroke = Instance.new("UIStroke")
    containerStroke.Thickness = 1
    containerStroke.Color = Color3.fromRGB(40, 40, 40)
    containerStroke.Parent = container

    window.Container = container
    window.Sidebar = sidebar
    
    -- Generate Default Info Tab automatically
    window:CreateInfoTab()
    
    return window
end

function CozyUI:CreateTab(tabName)
    local tab = {}
    
    -- Navigation Button inside Sidebar
    local tabBtn = Instance.new("TextButton")
    tabBtn.Size = UDim2.new(1, 0, 0, 28)
    tabBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    tabBtn.Text = " " .. tabName
    tabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    tabBtn.Font = Enum.Font.Code
    tabBtn.TextSize = 12
    tabBtn.TextXAlignment = Enum.TextXAlignment.Left
    tabBtn.Parent = self.Sidebar
    
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 1
    btnStroke.Color = Color3.fromRGB(30, 30, 30)
    btnStroke.Parent = tabBtn

    -- Elements Page Window Container
    local page = Instance.new("ScrollingFrame")
    page.Size = UDim2.new(1, -10, 1, -10)
    page.Position = UDim2.new(0, 5, 0, 5)
    page.BackgroundTransparency = 1
    page.Visible = false
    page.CanvasSize = UDim2.new(0, 0, 0, 0)
    page.AutomaticSize = Enum.AutomaticSize.Y
    page.ScrollBarThickness = 2
    page.ScrollBarImageColor3 = Color3.fromRGB(255, 255, 255)
    page.Parent = self.Container
    
    local pageLayout = Instance.new("UIListLayout")
    pageLayout.Padding = UDim.new(0, 6)
    pageLayout.Parent = page
    
    tabBtn.MouseButton1Click:Connect(function()
        for _, child in pairs(self.Container:GetChildren()) do
            if child:IsA("ScrollingFrame") or child:IsA("Frame") then
                child.Visible = false
            end
        end
        page.Visible = true
    end)
    
    -- Automatically make first tab visible
    if #self.Sidebar:GetChildren() == 2 then -- UIListLayout counts as 1 child
        page.Visible = true
    end
    
    -- Custom Element Adders inside Tab object
    function tab:CreateButton(name, callback)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -5, 0, 30)
        btn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
        btn.Text = name
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.Code
        btn.TextSize = 12
        btn.Parent = page
        
        local s = Instance.new("UIStroke")
        s.Thickness = 1
        s.Color = Color3.fromRGB(255, 255, 255)
        s.Parent = btn
        
        btn.MouseButton1Click:Connect(function()
            -- Minimalist flash visual effect on execution
            btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            btn.TextColor3 = Color3.fromRGB(0, 0, 0)
            task.wait(0.05)
            btn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            
            pcall(callback)
        end)
    end
    
    return tab
end

function CozyUI:CreateInfoTab()
    -- Create standard structure for display panel
    local infoBtn = Instance.new("TextButton")
    infoBtn.Size = UDim2.new(1, 0, 0, 28)
    infoBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    infoBtn.Text = " Info Panel"
    infoBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    infoBtn.Font = Enum.Font.Code
    infoBtn.TextSize = 12
    infoBtn.TextXAlignment = Enum.TextXAlignment.Left
    infoBtn.Parent = self.Sidebar
    
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 1
    btnStroke.Color = Color3.fromRGB(255, 255, 255)
    btnStroke.Parent = infoBtn

    local infoPage = Instance.new("Frame")
    infoPage.Size = UDim2.new(1, -10, 1, -10)
    infoPage.Position = UDim2.new(0, 5, 0, 5)
    infoPage.BackgroundTransparency = 1
    infoPage.Visible = false
    infoPage.Parent = self.Container
    
    -- Labels
    local userLabel = Instance.new("TextLabel")
    userLabel.Size = UDim2.new(0.5, 0, 0, 20)
    userLabel.Position = UDim2.new(0, 5, 0, 10)
    userLabel.BackgroundTransparency = 1
    userLabel.Text = "User: " .. LocalPlayer.Name
    userLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    userLabel.Font = Enum.Font.Code
    userLabel.TextSize = 12
    userLabel.TextXAlignment = Enum.TextXAlignment.Left
    userLabel.Parent = infoPage

    local displayLabel = userLabel:Clone()
    displayLabel.Position = UDim2.new(0, 5, 0, 30)
    displayLabel.Text = "Display: " .. LocalPlayer.DisplayName
    displayLabel.Parent = infoPage

    local ageLabel = userLabel:Clone()
    ageLabel.Position = UDim2.new(0, 5, 0, 50)
    ageLabel.Text = "Account Age: " .. tostring(LocalPlayer.AccountAge) .. " days"
    ageLabel.Parent = infoPage
    
    -- 3D Viewport Box Frame setup
    local viewport = Instance.new("ViewportFrame")
    viewport.Size = UDim2.new(0, 150, 0, 180)
    viewport.Position = UDim2.new(1, -160, 0, 10)
    viewport.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    viewport.Parent = infoPage
    
    local vStroke = Instance.new("UIStroke")
    vStroke.Thickness = 1
    vStroke.Color = Color3.fromRGB(60, 60, 60)
    vStroke.Parent = viewport
    
    -- Setup Viewport View Character Matrix
    task.spawn(function()
        LocalPlayer.CharacterAppearanceLoaded:Wait()
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        char.Archivable = true
        local clone = char:Clone()
        clone.Parent = viewport
        
        local hrp = clone:WaitForChild("HumanoidRootPart")
        local cam = Instance.new("Camera")
        cam.CFrame = CFrame.new(hrp.Position + (hrp.CFrame.LookVector * 5), hrp.Position)
        viewport.CurrentCamera = cam
        cam.Parent = viewport
    end)

    infoBtn.MouseButton1Click:Connect(function()
        for _, child in pairs(self.Container:GetChildren()) do
            if child:IsA("ScrollingFrame") or child:IsA("Frame") then
                child.Visible = false
            end
        end
        infoPage.Visible = true
    end)
end

