    runBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    runBtn.Font = Enum.Font.Code
    runBtn.TextSize = 11
    runBtn.Parent = execPage
    
    local rbStroke = Instance.new("UIStroke")
    rbStroke.Thickness = 1
    rbStroke.Color = Color3.fromRGB(255, 255, 255)
    rbStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    rbStroke.Parent = runBtn
    
    local clearBtn = Instance.new("TextButton")
    clearBtn.Size = UDim2.new(0.5, -3, 0, 28)
    clearBtn.Position = UDim2.new(0.5, 3, 1, -28)
    clearBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    clearBtn.BorderSizePixel = 0
    clearBtn.Text = "Clear"
    clearBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    clearBtn.Font = Enum.Font.Code
    clearBtn.TextSize = 11
    clearBtn.Parent = execPage
    
    local cbStroke = Instance.new("UIStroke")
    cbStroke.Thickness = 1
    cbStroke.Color = Color3.fromRGB(255, 255, 255)
    cbStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    cbStroke.Parent = clearBtn
    
    runBtn.MouseButton1Click:Connect(function()
        local code = textBox.Text
        if code and code ~= "" then
            local func, err = loadstring(code)
            if func then task.spawn(func) end
        end
    end)
    
    clearBtn.MouseButton1Click:Connect(function()
        textBox.Text = ""
    end)

    execBtn.MouseButton1Click:Connect(function()
        for _, p in pairs(window.Pages) do p.Visible = false end
        for _, b in pairs(window.TabButtons) do 
            b.TextColor3 = Color3.fromRGB(130, 130, 130)
            b.UIStroke.Color = Color3.fromRGB(80, 80, 80)
        end
        execPage.Visible = true
        execBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        execBtn.UIStroke.Color = Color3.fromRGB(255, 255, 255)
    end)
end

-- Integrated Native Info Viewport Tab (Always Forced Above Executor)
function CozyUI:CreateNativeInfo()
    local window = self
    
    local infoBtn = Instance.new("TextButton")
    infoBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    infoBtn.BorderSizePixel = 0
    infoBtn.Text = "Info"
    infoBtn.TextColor3 = Color3.fromRGB(130, 130, 130)
    infoBtn.Font = Enum.Font.Code
    infoBtn.TextSize = 11
    infoBtn.LayoutOrder = 998 -- Forced directly above the Executor
    infoBtn.Parent = self.NavFrame
    
    local infStroke = Instance.new("UIStroke")
    infStroke.Thickness = 1
    infStroke.Color = Color3.fromRGB(80, 80, 80)
    infStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    infStroke.Parent = infoBtn
    table.insert(window.TabButtons, infoBtn)

    local infoPage = Instance.new("Frame")
    infoPage.Size = UDim2.new(1, -12, 1, -12)
    infoPage.Position = UDim2.new(0, 6, 0, 6)
    infoPage.BackgroundTransparency = 1
    infoPage.Visible = false
    infoPage.Parent = self.Container
    table.insert(window.Pages, infoPage)

    local viewport = Instance.new("ViewportFrame")
    viewport.Size = UDim2.new(1, 0, 1, 0)
    viewport.Position = UDim2.new(0, 0, 0, 0)
    viewport.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    viewport.BorderSizePixel = 0
    viewport.Parent = infoPage
    
    local vStroke = Instance.new("UIStroke")
    vStroke.Thickness = 1
    vStroke.Color = Color3.fromRGB(255, 255, 255)
    vStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    vStroke.Parent = viewport
    
    task.spawn(function()
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        char.Archivable = true
        task.wait(0.5)
        local clone = char:Clone()
        clone.Parent = viewport
        
        local hrp = clone:WaitForChild("HumanoidRootPart")
        local cam = Instance.new("Camera")
        viewport.CurrentCamera = cam
        cam.Parent = viewport
        
        local rotAngle = 0
        game:GetService("RunService").Heartbeat:Connect(function()
            rotAngle = rotAngle + 1
            cam.CFrame = CFrame.new(hrp.Position + Vector3.new(math.sin(math.rad(rotAngle)) * 5, 2, math.cos(math.rad(rotAngle)) * 5), hrp.Position)
        end)
    end)

    infoBtn.MouseButton1Click:Connect(function()
        for _, p in pairs(window.Pages) do p.Visible = false end
        for _, b in pairs(window.TabButtons) do 
            b.TextColor3 = Color3.fromRGB(130, 130, 130)
            b.UIStroke.Color = Color3.fromRGB(80, 80, 80)
        end
        infoPage.Visible = true
        infoBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        infoBtn.UIStroke.Color = Color3.fromRGB(255, 255, 255)
    end)
end

return CozyUI
