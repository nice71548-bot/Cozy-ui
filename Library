local Workspace = game:GetService("Workspace")

local function getRandomName()
    local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
    local name = ""
    for i = 1, 14 do
        local rand = math.random(1, #chars)
        name = name .. string.sub(chars, rand, rand)
    end
    return name
end

-- Clean touch/mouse dragging handler
local function makeDraggable(frame, handle)
    local dragging, dragInput, dragStart, startPos
    
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X, 
                startPos.Y.Scale, 
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

function CozyUI:CreateWindow(config)
    local window = setmetatable({}, CozyUI)
    window.Title = config.Name or "Cozy Hub"
    window.TabButtons = {}
    window.Pages = {}
    window.CustomTabsCount = 0
    
    -- ScreenGui Setup
    local sgui = Instance.new("ScreenGui")
    sgui.Name = getRandomName()
    sgui.ResetOnSpawn = false
    sgui.DisplayOrder = 999
    
    local success, p = pcall(function() return gethui() end)
    sgui.Parent = (success and p) or CoreGui
    window.ScreenGui = sgui
    
    -- Main Window Frame
    local mainFrame = Instance.new("Frame")
    mainFrame.Name = getRandomName()
    mainFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    mainFrame.BorderSizePixel = 0
    mainFrame.Active = true
    mainFrame.Parent = sgui
    window.MainFrame = mainFrame
    
    -- Outer Border Outline
    local mainStroke = Instance.new("UIStroke")
    mainStroke.Thickness = 1
    mainStroke.Color = Color3.fromRGB(255, 255, 255)
    mainStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    mainStroke.Parent = mainFrame

    -- Drag Header Bar
    local topBar = Instance.new("Frame")
    topBar.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    topBar.BorderSizePixel = 0
    topBar.Parent = mainFrame
    
    local headerDivider = Instance.new("Frame")
    headerDivider.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    headerDivider.BorderSizePixel = 0
    headerDivider.Parent = topBar

    local titleLabel = Instance.new("TextLabel")
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = window.Title
    titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    titleLabel.Font = Enum.Font.Code
    titleLabel.TextSize = 13
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = topBar
    
    makeDraggable(mainFrame, topBar)
    
    -- Navigation Frame Container
    local navFrame = Instance.new("Frame")
    navFrame.BackgroundTransparency = 1
    navFrame.Parent = mainFrame
    
    local navLayout = Instance.new("UIListLayout")
    navLayout.Padding = UDim.new(0, 6)
    navLayout.FillDirection = Enum.FillDirection.Vertical
    navLayout.Parent = navFrame
    
    -- Main Element Container Frame
    local container = Instance.new("Frame")
    container.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    container.BorderSizePixel = 0
    container.Parent = mainFrame
    
    local containerStroke = Instance.new("UIStroke")
    containerStroke.Thickness = 1
    containerStroke.Color = Color3.fromRGB(255, 255, 255)
    containerStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    containerStroke.Parent = container

    window.NavFrame = navFrame
    window.NavLayout = navLayout
    window.Container = container
    
    -- Minimize / Maximize Core Button
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 20, 0, 20)
    closeBtn.Position = UDim2.new(1, -25, 0, 5)
    closeBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    closeBtn.BorderSizePixel = 0
    closeBtn.Text = "X"
    closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeBtn.Font = Enum.Font.Code
    closeBtn.TextSize = 12
    closeBtn.Parent = topBar
    
    local closeStroke = Instance.new("UIStroke")
    closeStroke.Thickness = 1
    closeStroke.Color = Color3.fromRGB(255, 255, 255)
    closeStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    closeStroke.Parent = closeBtn
    
    -- Minimized Little Square Button
    local miniFrame = Instance.new("Frame")
    miniFrame.Size = UDim2.new(0, 60, 0, 30)
    miniFrame.Position = UDim2.new(0.5, -30, 0.1, 0)
    miniFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    miniFrame.BorderSizePixel = 0
    miniFrame.Visible = false
    miniFrame.Active = true
    miniFrame.Parent = sgui
    
    local miniStroke = Instance.new("UIStroke")
    miniStroke.Thickness = 1
    miniStroke.Color = Color3.fromRGB(255, 255, 255)
    miniStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    miniStroke.Parent = miniFrame
    
    local miniBtn = Instance.new("TextButton")
    miniBtn.Size = UDim2.new(1, 0, 1, 0)
    miniBtn.BackgroundTransparency = 1
    miniBtn.Text = "Cozy"
    miniBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    miniBtn.Font = Enum.Font.Code
    miniBtn.TextSize = 12
    miniBtn.Parent = miniFrame
    
    makeDraggable(miniFrame, miniFrame)
    
    closeBtn.MouseButton1Click:Connect(function()
        mainFrame.Visible = false
        miniFrame.Position = UDim2.new(0, mainFrame.AbsolutePosition.X + 10, 0, mainFrame.AbsolutePosition.Y + 10)
        miniFrame.Visible = true
    end)
    
    miniBtn.MouseButton1Click:Connect(function()
        miniFrame.Visible = false
        mainFrame.Visible = true
    end)

    -- Dynamic PC vs. Mobile Screen Sizer Layout
    local camera = Workspace.CurrentCamera
    local function adjustLayoutSizes()
        local viewportSize = camera.ViewportSize
        if viewportSize.X <= 768 then
            -- Mobile UI Boundaries
            mainFrame.Size = UDim2.new(0, 390, 0, 245)
            mainFrame.Position = UDim2.new(0.5, -195, 0.5, -122)
            
            topBar.Size = UDim2.new(1, 0, 0, 30)
            topBar.Position = UDim2.new(0, 0, 0, 0)
            
            titleLabel.Size = UDim2.new(1, -40, 1, 0)
            titleLabel.Position = UDim2.new(0, 10, 0, 0)
            
            headerDivider.Size = UDim2.new(1, 0, 0, 1)
            headerDivider.Position = UDim2.new(0, 0, 1, -1)
            
            navFrame.Size = UDim2.new(1, -20, 0, 30)
            navFrame.Position = UDim2.new(0, 10, 0, 36)
            navLayout.FillDirection = Enum.FillDirection.Horizontal
            
            container.Size = UDim2.new(1, -20, 1, -80)
            container.Position = UDim2.new(0, 10, 0, 72)
        else
            -- PC UI Boundaries
            mainFrame.Size = UDim2.new(0, 560, 0, 340)
            mainFrame.Position = UDim2.new(0.5, -280, 0.5, -170)
            
            topBar.Size = UDim2.new(1, 0, 0, 32)
            topBar.Position = UDim2.new(0, 0, 0, 0)
            
            titleLabel.Size = UDim2.new(1, -40, 1, 0)
            titleLabel.Position = UDim2.new(0, 12, 0, 0)
            
            headerDivider.Size = UDim2.new(1, 0, 0, 1)
            headerDivider.Position = UDim2.new(0, 0, 1, -1)
            
            navFrame.Size = UDim2.new(0, 110, 1, -44)
            navFrame.Position = UDim2.new(0, 10, 0, 38)
            navLayout.FillDirection = Enum.FillDirection.Vertical
            
            container.Size = UDim2.new(1, -142, 1, -44)
            container.Position = UDim2.new(0, 132, 0, 38)
        end
        
        -- Resize button sizes within navigation grid properly
        for _, btn in pairs(window.TabButtons) do
            if navLayout.FillDirection == Enum.FillDirection.Horizontal then
                btn.Size = UDim2.new(0, 70, 1, 0)
            else
                btn.Size = UDim2.new(1, 0, 0, 28)
            end
        end
    end
    
    adjustLayoutSizes()
    camera:GetPropertyChangedSignal("ViewportSize"):Connect(adjustLayoutSizes)
    window.AdjustLayoutSizes = adjustLayoutSizes

    -- Force Executor and Info setup instantly
    window:CreateNativeInfo()
    window:CreateNativeExecutor()
    
    return window
end

function CozyUI:CreateTab(tabName)
    local tab = {}
    local window = self
    window.CustomTabsCount = window.CustomTabsCount + 1
    
    -- Custom Script Square Tab Button
    local tabBtn = Instance.new("TextButton")
    tabBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    tabBtn.BorderSizePixel = 0
    tabBtn.Text = tabName
    tabBtn.TextColor3 = Color3.fromRGB(130, 130, 130)
    tabBtn.Font = Enum.Font.Code
    tabBtn.TextSize = 11
    tabBtn.LayoutOrder = window.CustomTabsCount -- Kept at the top
    tabBtn.Parent = self.NavFrame
    
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 1
    btnStroke.Color = Color3.fromRGB(80, 80, 80)
    btnStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    btnStroke.Parent = tabBtn
    
    table.insert(window.TabButtons, tabBtn)

    -- Viewport Page Container
    local page = Instance.new("ScrollingFrame")
    page.Size = UDim2.new(1, -12, 1, -12)
    page.Position = UDim2.new(0, 6, 0, 6)
    page.BackgroundTransparency = 1
    page.Visible = false
    page.CanvasSize = UDim2.new(0, 0, 0, 0)
    page.AutomaticSize = Enum.AutomaticSize.Y
    page.ScrollBarThickness = 2
    page.ScrollBarImageColor3 = Color3.fromRGB(255, 255, 255)
    page.BorderSizePixel = 0
    page.Parent = self.Container
    
    local pageLayout = Instance.new("UIListLayout")
    pageLayout.Padding = UDim.new(0, 6)
    pageLayout.Parent = page
    
    table.insert(window.Pages, page)
    
    local function selectThisTab()
        for _, p in pairs(window.Pages) do p.Visible = false end
        for _, b in pairs(window.TabButtons) do 
            b.TextColor3 = Color3.fromRGB(130, 130, 130)
            b.UIStroke.Color = Color3.fromRGB(80, 80, 80)
        end
        page.Visible = true
        tabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        tabBtn.UIStroke.Color = Color3.fromRGB(255, 255, 255)
    end
    
    tabBtn.MouseButton1Click:Connect(selectThisTab)
    if #window.Pages == 1 then selectThisTab() end
    
    -- Adds buttons inside this tab layout
    function tab:CreateButton(name, callback)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -4, 0, 28)
        btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        btn.BorderSizePixel = 0
        btn.Text = name
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.Code
        btn.TextSize = 11
        btn.Parent = page
        
        local s = Instance.new("UIStroke")
        s.Thickness = 1
        s.Color = Color3.fromRGB(255, 255, 255)
        s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        s.Parent = btn
        
        btn.MouseButton1Click:Connect(function()
            pcall(callback)
        end)
    end
    
    -- Dynamically realigns dimensions of buttons inside NavFrame
    window.AdjustLayoutSizes()
    
    return tab
end

